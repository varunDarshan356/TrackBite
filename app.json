{
  "expo": {
    "name": "trackbite",
    "slug": "trackbite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "trackbite",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios-icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-512.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bagelsilverberryleaf.trackbite"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/android-splash-1024x1024.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/android-splash-1024x1024.png",
            "resizeMode": "contain",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f632d137-16ae-4ffc-a6d3-78255e049243"
      }
    }
  }
}
